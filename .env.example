# ─── MySQL (matches docker-compose.yml defaults) ───────────────────────────────
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=helfy_home
MYSQL_USER=helfy
MYSQL_PASSWORD=helfypassword

# ─── Backend ────────────────────────────────────────────────────────────────────
# Copy this file to backend/.env and fill in real values
PORT=3001
NODE_ENV=development

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=helfy_home
DB_USER=helfy
DB_PASSWORD=helfypassword

JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars

FRONTEND_ORIGIN=http://localhost:5173

# ─── Frontend ───────────────────────────────────────────────────────────────────
# Copy this file to frontend/.env and fill in real values
VITE_API_BASE_URL=/api